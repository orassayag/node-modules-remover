{
  "name": "node-modules-remover",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "A TypeScript CLI tool that recursively scans and removes node_modules directories with real-time progress, intelligent filtering, and comprehensive statistics",
  "keywords": [
    "node-modules",
    "cleanup",
    "disk-space",
    "cli",
    "typescript",
    "filesystem",
    "developer-tools",
    "nodejs",
    "disk-cleanup",
    "storage-management"
  ],
  "author": "Or Assayag",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orassayag/node-modules-remover"
  },
  "bugs": {
    "url": "https://github.com/orassayag/node-modules-remover/issues"
  },
  "homepage": "https://github.com/orassayag/node-modules-remover#readme",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "build": "tsc",
    "test": "cross-env NODE_OPTIONS='--no-warnings' vitest run --coverage",
    "test:watch": "cross-env NODE_OPTIONS='--no-warnings' vitest",
    "test:no-coverage": "cross-env NODE_OPTIONS='--no-warnings' vitest run",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prettier": "prettier --check 'src/**/*.ts'",
    "prettier:fix": "prettier --write 'src/**/*.ts'"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-istanbul": "^4.1.8",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
